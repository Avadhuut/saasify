						"description": "Creates a new user under user-service management, checking quotas first."
					},
					"response": []
				},
				{
					"name": "Get User By ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Tenant-ID",
								"value": "acme",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{saasify_jwt}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/api/users/{{saasify_user_id}}",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
								"api",
								"users",
								"{{saasify_user_id}}"
							]
						},
						"description": "Fetches a single user details inside active tenant's schema."
					},
					"response": []
				},
				{
					"name": "Update User",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "X-Tenant-ID",
								"value": "acme",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{saasify_jwt}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role\": \"VIEWER\",\n  \"isActive\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "http://localhost:8080/api/users/{{saasify_user_id}}",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
								"api",
								"users",
								"{{saasify_user_id}}"
							]
						},
						"description": "Updates user metadata inside active tenant's schema."
					},
					"response": []
				},
				{
					"name": "Delete User",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "X-Tenant-ID",
								"value": "acme",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{saasify_jwt}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/api/users/{{saasify_user_id}}",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
								"api",
								"users",
								"{{saasify_user_id}}"
							]
						},
						"description": "Removes a user row from active tenant's schema."
					},
					"response": []
				}
			]
		},
