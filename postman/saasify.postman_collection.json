						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"member1@acme.com\",\n  \"password\": \"AcmeMember123!\",\n  \"role\": \"MEMBER\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "http://localhost:8080/api/users",
